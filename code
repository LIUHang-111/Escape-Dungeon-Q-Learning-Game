    "# Q表容器类\n",
    "class QTable:\n",
    "    def __init__(self, state_size, action_size):\n",
    "        self.state_size = state_size\n",
    "        self.action_size = action_size\n",
    "        self.Q_value = np.zeros((self.state_size, self.action_size))\n",
    "\n",
    "    def get_q_value(self, state, action):\n",
    "        return self.Q_value[util.coordinates_to_index(state), util.action_to_index(action)]\n",
    "\n",
    "    def set_q_value(self, state, action, value):\n",
    "        self.Q_value[util.coordinates_to_index(state), util.action_to_index(action)] = value\n",
    "\n",
    "# Q学习智能体类\n",
    "class QLearningAgent:\n",
    "    def __init__(self, q_table, game_map, gamma, epsilon, epsilon_decay, epsilon_min, learning_rate):\n",
    "        self.game_map = game_map\n",
    "        self.Q = q_table\n",
    "        self.epsilon = epsilon\n",
    "        self.epsilon_decay = epsilon_decay\n",
    "        self.epsilon_min = epsilon_min\n",
    "        self.gamma = gamma\n",
    "        self.learning_rate = learning_rate\n",
    "\n",
    "\n",
    "    def max_q_value_of_state(self, state):\n",
    "        # 获取所有合法动作\n",
    "        legal_actions = self.game_map.get_legal_directions(state)\n",
    "        if not legal_actions:\n",
    "            return 0\n",
    "\n",
    "        #计算该状态所有动作的最大Q值\n",
    "        q_value_max = float(\"-inf\")\n",
    "        for action in legal_actions:\n",
    "            if self.Q.get_q_value(state, action) > q_value_max:\n",
    "                q_value_max = self.Q.get_q_value(state, action)\n",
    "\n",
    "        return q_value_max\n",
    "\n",
    "    def best_action(self, state):\n",
    "        # 获取所有合法动作\n",
    "        legal_actions = self.game_map.get_legal_directions(state)\n",
    "        if not legal_actions:\n",
    "            return 0\n",
    "\n",
    "        best_action = None\n",
    "        q_value_max = float(\"-inf\")\n",
    "        for action in legal_actions:\n",
    "            if self.Q.get_q_value(state, action) > q_value_max:\n",
    "                q_value_max = self.Q.get_q_value(state, action)\n",
    "                best_action = action\n",
    "\n",
    "        return best_action\n",
    "\n",
    "    def choose_action(self, state):\n",
    "        # 获取所有合法动作\n",
    "        legal_actions = self.game_map.get_legal_directions(state)\n",
    "        if not legal_actions:\n",
    "            return None\n",
    "\n",
    "        action = None\n",
    "\n",
    "        #epsilon贪心策略\n",
    "        if util.flip_coin_probability(self.epsilon):\n",
    "            action = random.choice(legal_actions)\n",
    "        else:\n",
    "            action = self.best_action(state)\n",
    "\n",
    "        return action\n",
    "\n",
    "    def update(self, state, action, reward, next_state):\n",
    "        #获取当前状态动作的旧 q 值\n",
    "        old_q_value = self.Q.get_q_value(state, action)\n",
    "        #获取下一状态的最优 q 值\n",
    "        next_q_value = self.max_q_value_of_state(next_state)\n",
    "        #应用Q学习公式\n",
    "        new_q_value = old_q_value + self.learning_rate * (reward + self.gamma * next_q_value - old_q_value)\n",
    "        #更新q值\n",
    "        self.Q.set_q_value(state, action, new_q_value)\n",
    "\n",
    "    def dec_epsilon(self):\n",
    "        if self.epsilon > self.epsilon_min:\n",
    "            self.epsilon *= self.epsilon_decay\n",
